.gcloudignore
gcloud-service-key.json

# IDE
.idea/
.vscode/
*.swp
*.swo

# macOS
.DS_Store
.AppleDouble

# Test and coverage output
*.coverprofile

# Local deployment scripts with sensitive values
deploy-local.sh

# AI stuff
.claude