# Gemini environment variables. Set with your own project id.
GEMINI_PROJECT_ID="your-gemini-project-id"
GEMINI_LOCATION="us-central1"

# Path for extraction configs as JSON, either local -or GCS if starts with "gs://".
CONFIG_PATH="config.json"

# Cloud Run environment variables. Set with your own project id.
CLOUD_RUN_PROJECT_ID="your-cloud-run-project-id"
CLOUD_RUN_REGION="us-central1"
SERVICE_NAME="entity-extraction-service"

# Location of image paths and prefix in Google Cloud Storage for evaluation.
IMAGE_PATHS = "gs://github-repo/generative-ai/gemini/use-cases/entity-extraction/images.csv"
IMAGE_PREFIX = "gs://github-repo/generative-ai/gemini/use-cases/entity-extraction"
EVAL_DEST = "gs://path/to/evaluations"
